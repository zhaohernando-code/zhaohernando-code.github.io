---
const cases = [
  {
    title: '文件整理',
    body: '归档混乱目录、清理重复文件、重命名素材，让桌面从任务堆变回工作台。',
    image: '/assets/images/gallery/file_organize.png',
    alt: '文件整理场景',
  },
  {
    title: '远程文件查找',
    body: '在路上给 OpenDesk 发消息，让它从电脑里找到文件并回传。',
    image: '/assets/images/gallery/file_transfer.png',
    alt: '远程文件查找场景',
  },
];
---

<section id="gallery" class="home-gallery-band snap-page">
  <div class="home-gallery__inner">
    <h2><span class="title-line">为繁琐任务保留一个</span><span class="title-line">可靠的执行者</span></h2>
    <div class="home-gallery__grid">
      {
        cases.map((item) => (
          <article class="home-case">
            <img src={item.image} alt={item.alt} />
            <div class="home-case__caption">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
