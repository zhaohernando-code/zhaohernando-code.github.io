---
import { site } from '../config/site';
import SiteSearch from './header/SiteSearch.astro';
import ThemeToggle from './header/ThemeToggle.astro';

interface Props {
  variant?: 'default' | 'landing';
}

const { variant = 'default' } = Astro.props;
const navItems = site.nav;
const eagerPrefetchHrefs = new Set(['/docs/quickstart/cli/', '/gallery/']);
const getDesktopPrefetchMode = (href: string, external?: boolean) => {
  if (external) return undefined;
  return eagerPrefetchHrefs.has(href) ? 'load' : 'hover';
};
const getMobilePrefetchMode = (external?: boolean) => (external ? undefined : 'tap');
---

<site-header-menu transition:persist="site-header">
  <header class:list={['site-header', variant === 'landing' && 'site-header--landing']}>
    <div class="site-header__inner">
      <a class="site-brand" href="/" aria-label="OpenDesk">
        <img src="/assets/images/cli-logo.png" alt="" width="148" height="34" />
        <span>{site.title}</span>
      </a>
      <div class="site-header__search">
        <SiteSearch />
      </div>
      <div class="site-header__right">
        <button type="button" class="site-menu-toggle" data-menu-toggle aria-expanded="false" aria-controls="site-mobile-menu" aria-label="打开导航菜单">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav class="site-nav" aria-label="Main navigation">
          {
            navItems.map((item) => (
              <div class:list={['site-nav__item', item.external && 'site-nav__item--external', item.items && 'site-nav__item--has-menu']}>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noreferrer' : undefined}
                  data-nav-link
                  data-nav-external={item.external ? 'true' : undefined}
                  data-astro-prefetch={getDesktopPrefetchMode(item.href, item.external)}
                >
                  {item.label}
                </a>
                {
                  item.items && (
                    <div class="site-nav__menu">
                      {item.items.map((child) => (
                        <a href={child.href}>{child.label}</a>
                      ))}
                    </div>
                  )
                }
              </div>
            ))
          }
          <div class="site-nav__item site-nav__item--external">
            <a href={site.repoUrl} target="_blank" rel="noreferrer" data-nav-link data-nav-external="true">代码仓</a>
          </div>
        </nav>
        <div class="site-actions">
          <ThemeToggle />
        </div>
      </div>
      <div id="site-mobile-menu" class="site-mobile-menu" data-mobile-menu hidden>
        <nav class="site-mobile-tabs" aria-label="Mobile navigation">
          {
            navItems.map((item) => (
              <div class:list={['site-mobile-tabs__item', item.external && 'site-mobile-tabs__item--external', item.items && 'site-mobile-tabs__item--group']}>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noreferrer' : undefined}
                  data-nav-link
                  data-nav-external={item.external ? 'true' : undefined}
                  data-astro-prefetch={getMobilePrefetchMode(item.external)}
                >
                  {item.label}
                </a>
                {
                  item.items && (
                    <div class="site-mobile-tabs__children">
                      {item.items.map((child) => (
                        <a href={child.href}>{child.label}</a>
                      ))}
                    </div>
                  )
                }
              </div>
            ))
          }
          <div class="site-mobile-tabs__item site-mobile-tabs__item--external">
            <a href={site.repoUrl} target="_blank" rel="noreferrer" data-nav-link data-nav-external="true">代码仓</a>
          </div>
        </nav>
        <div class="site-mobile-menu__actions">
          <ThemeToggle />
        </div>
      </div>
    </div>
  </header>
</site-header-menu>

<script>
  class SiteHeaderMenu extends HTMLElement {
    connectedCallback() {
      this.abortController?.abort();
      const controller = new AbortController();
      this.abortController = controller;

      const button = this.querySelector('[data-menu-toggle]');
      const menu = this.querySelector('[data-mobile-menu]');
      if (!button || !menu) return;
      const header = this.querySelector('.site-header');

      const close = () => {
        menu.hidden = true;
        button.setAttribute('aria-expanded', 'false');
        button.setAttribute('aria-label', '打开导航菜单');
      };
      const open = () => {
        menu.hidden = false;
        button.setAttribute('aria-expanded', 'true');
        button.setAttribute('aria-label', '关闭导航菜单');
      };
      const syncVariant = () => {
        header?.classList.toggle('site-header--landing', window.location.pathname === '/');
      };
      const normalizePath = (value) => {
        const url = new URL(value, window.location.origin);
        if (url.origin !== window.location.origin) return null;
        if (url.pathname === '/') return '/';
        return url.pathname.replace(/\/+$/, '');
      };
      const syncActiveLinks = () => {
        const currentPath = normalizePath(window.location.href);
        this.querySelectorAll('[data-nav-link]').forEach((link) => {
          const item = link.closest('.site-nav__item, .site-mobile-tabs__item');
          const targetPath = link.dataset.navExternal === 'true' ? null : normalizePath(link.href);
          const isActive = Boolean(
            currentPath &&
              targetPath &&
              (targetPath === '/'
                ? currentPath === '/'
                : currentPath === targetPath || currentPath.startsWith(`${targetPath}/`)),
          );

          item?.classList.toggle('site-nav__item--active', isActive);
          item?.classList.toggle('site-mobile-tabs__item--active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'page');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };
      const syncVariantAfterSwap = () => {
        window.requestAnimationFrame(() => {
          syncVariant();
          syncActiveLinks();
        });
      };

      syncVariant();
      syncActiveLinks();
      button.addEventListener('click', () => {
        menu.hidden ? open() : close();
      }, { signal: controller.signal });
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', close, { signal: controller.signal });
      });
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') close();
      }, { signal: controller.signal });
      document.addEventListener('astro:before-swap', close, { signal: controller.signal });
      document.addEventListener('astro:after-swap', syncVariantAfterSwap, { signal: controller.signal });
      document.addEventListener('astro:page-load', syncVariantAfterSwap, { signal: controller.signal });
    }

    disconnectedCallback() {
      this.abortController?.abort();
    }
  }

  if (!customElements.get('site-header-menu')) customElements.define('site-header-menu', SiteHeaderMenu);
</script>
