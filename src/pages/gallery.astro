---
import SiteLayout from '../layouts/SiteLayout.astro';

const cases = [
  {
    title: '文件整理',
    href: '/gallery/file_organize/',
    image: '/assets/images/gallery/file_organize_small.png',
    alt: '整理文件',
    description:
      '把混乱的目录重新归档，清理过时或重复的内容，自动把文件改成合适的名字。',
  },
  {
    title: '远程文件查找',
    href: '/gallery/file_transfer/',
    image: '/assets/images/gallery/file_transfer_small.png',
    alt: '远程文件查找',
    description:
      '出差路上急需电脑上的重要文件时，通过飞书机器人等渠道联系 OpenDesk 快速找到内容。',
  },
  {
    title: '批量文件处理',
    href: '/gallery/file_batch/',
    image: '/assets/images/gallery/file_batch_small.png',
    alt: '批量文件处理',
    description:
      '把压缩视频、裁剪图片、调整格式等重复动作交给 OpenDesk 连续执行。',
  },
];
---

<SiteLayout frontmatter={{ title: '使用场景' }}>
  <section class="content-page gallery-page">
    <h1>使用场景</h1>
    <p>
      OpenDesk 是一个可以组合模型、MCP、Skills 和消息渠道的通用智能体。你可以随意安排它做事；
      这里先整理一些高频场景，帮助你更快建立自己的桌面工作流。
    </p>

    <h2>文件管理和远程控制</h2>
    <div class="gallery-grid">
      {
        cases.map((item) => (
          <a class="gallery-card" href={item.href}>
            <img src={item.image} alt={item.alt} loading="lazy" />
            <span>{item.title}</span>
            <p>{item.description}</p>
          </a>
        ))
      }
    </div>

    <h2>开发运维和定时任务</h2>
    <p>后续会继续补充开发、运维、定时任务、信息监控等场景案例。</p>
  </section>
</SiteLayout>
