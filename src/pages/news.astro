---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';

const notes = (await getCollection('releaseNotes')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const notesByYear = notes.reduce<Map<string, typeof notes>>((groups, note) => {
  const year = String(note.data.date.getFullYear());
  groups.set(year, [...(groups.get(year) ?? []), note]);
  return groups;
}, new Map());

const formatDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const categoryLabels: Record<string, string> = {
  'nightly-release': 'Nightly',
  'stable-release': 'Stable',
};

const notePath = (id: string) => `/news/${id.replace(/\.mdx?$/, '')}/`;
---

<SiteLayout frontmatter={{ title: 'Release Notes', description: 'OpenDesk Release Notes' }}>
  <section class="content-page release-page">
    <h1>Release Notes</h1>
    <p>OpenDesk 的稳定版和 Nightly 构建更新记录。</p>

    {
      Array.from(notesByYear.entries()).map(([year, yearNotes]) => (
        <section class="release-year" aria-labelledby={`release-year-${year}`}>
          <h2 id={`release-year-${year}`}>{year}</h2>
          <ol class="release-list">
            {yearNotes.map((note) => (
              <li>
                <a href={notePath(note.id)}>
                  <time datetime={note.data.date.toISOString()}>{formatDate.format(note.data.date)}</time>
                  <span>{note.data.title}</span>
                </a>
                <span class="release-badge">{categoryLabels[note.data.category] ?? note.data.category}</span>
              </li>
            ))}
          </ol>
        </section>
      ))
    }
  </section>
</SiteLayout>
